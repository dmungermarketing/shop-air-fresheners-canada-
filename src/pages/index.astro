---
import Layout from '../layouts/Layout.astro';

// PLACEHOLDER — replace with your real Amazon storefront URL before publishing
const AMAZON_URL = 'https://www.amazon.ca/REPLACE-WITH-YOUR-STOREFRONT';

// Oopsie Poopsie — oil-based PRE-POOP toilet sprays (spray into the bowl before you go)
const oopsiePoopsie = [
  { name: 'Lemon Bergamot', notes: 'Lemon zest · bergamot · citrus', image: '/images/products/op-lemon-bergamot.webp' },
  { name: 'Lavender Escape', notes: 'Lavender · honey · pepper', image: '/images/products/op-lavender-escape.webp' },
  { name: 'Mediterranean Sage', notes: 'Fresh sage · sea salt', image: '/images/products/op-mediterranean-sage.webp' },
  { name: 'Berry Fresh', notes: 'Winterberry · pine', image: '/images/products/op-berry-fresh.webp' },
  { name: 'Morning Shower', notes: 'Morning dew · rose · baby powder', image: '/images/products/op-morning-shower.webp' },
  { name: 'Flower Citrus', notes: 'Lemongrass · orange blossom · eucalyptus', image: '/images/products/op-flower-citrus.webp' },
  { name: 'Summer Sea', notes: 'Fleur de sel · fig · sandalwood', image: '/images/products/op-summer-sea.webp' },
  { name: 'Wild Mint', notes: 'Mint · basil · pine', image: '/images/products/op-wild-mint.webp' },
];

// AROMAR+ Spa Room Mist — water-based 8 oz room & fabric mists (safe on linen, furniture, clothing)
const roomMists = [
  { name: 'Baby Powder', notes: 'Soft, clean, comforting powder', image: '/images/products/rm-baby-powder.webp' },
  { name: 'Channel #5*', notes: 'Classic French perfumery inspired', image: '/images/products/rm-channel.webp', star: true },
  { name: 'Eternal Life', notes: 'Timeless, serene, tranquil', image: '/images/products/rm-eternal-life.webp' },
  { name: 'Eucalyptus', notes: 'Invigorating, fresh, rejuvenating', image: '/images/products/rm-eucalyptus.webp' },
  { name: 'Honey Rose', notes: 'Honeyed warmth · delicate rose', image: '/images/products/rm-honey-rose.webp' },
  { name: 'Midnight Lover', notes: 'Seductive, mysterious, romantic', image: '/images/products/rm-midnight-lover.webp' },
  { name: 'Mulberry', notes: 'Sweet, fruity, ripe mulberry', image: '/images/products/rm-mulberry.webp' },
  { name: 'Sea Breeze', notes: 'Fresh coastal ocean air', image: '/images/products/rm-sea-breeze.webp' },
  { name: 'White Gardenia', notes: 'Delicate white florals', image: '/images/products/rm-white-gardenia.webp' },
  { name: 'Sandalwood Forest', notes: 'Warm, woody, grounding', image: '/images/products/rm-sandalwood-forest.webp' },
];

const faqs = [
  { q: 'How does Oopsie Poopsie pre-poop toilet spray work?', a: 'Spray 3–5 times directly into the toilet bowl water BEFORE you go. The oil-based formula floats on the water surface and forms an invisible barrier that traps odors before they rise into the room — so the bathroom stays fresh and no one ever knows.' },
  { q: 'What is the difference between Oopsie Poopsie and AROMAR+ Spa Room Mist?', a: 'Oopsie Poopsie is an oil-based pre-poop toilet spray — designed for the toilet bowl, sprayed onto the water before use. AROMAR+ Spa Room Mist is water-based with fragrance oil — a room and fabric mist for freshening rooms, linen, pillows, furniture and clothing. The room mist will not stain fabric.' },
  { q: 'Can I use AROMAR+ Spa Room Mist on fabric, linen and furniture?', a: 'Yes. AROMAR+ Spa Room Mist is water-based and designed for fabric. Spray on pillows, mattresses, couches, curtains, linen, clothing, gym bags and pet beds. The fragrance lasts and there is no oily residue or staining (we still recommend testing a hidden spot first).' },
  { q: 'How many sprays of Oopsie Poopsie should I use?', a: 'For best results, 3–5 sprays directly into the toilet bowl water before sitting down. The oil forms a thin floating layer that traps odors. A little goes a long way — one bottle lasts hundreds of uses.' },
  { q: 'Which Oopsie Poopsie fragrance should I choose?', a: 'Popular picks: Lemon Bergamot (bright citrus), Lavender Escape (calming, classic), Mediterranean Sage (earthy herbal), Berry Fresh (sweet fruity), Morning Shower (clean rose & powder), and Flower Citrus (uplifting floral). All 8 are made with essential oils — pick what suits your home best.' },
  { q: 'Will AROMAR+ Spa Room Mist stain my couch or pillows?', a: 'No. AROMAR+ Spa Room Mist is water-based — formulated to be safe on most fabrics including couches, pillows, mattresses and clothing. We recommend testing on a hidden area first. It dries clean with no oily residue.' },
  { q: 'How long does the Spa Room Mist fragrance last?', a: 'A few sprays freshen a room for several hours. On fabric and linen the scent typically holds 1–3 days depending on airflow and use. The 8 oz bottle lasts a long time for everyday use.' },
  { q: 'Where can I buy Oopsie Poopsie and AROMAR room mists in Canada?', a: 'Right here. Click any "Shop on Amazon" button and you will be taken to our Amazon Canada storefront. We are an independent Canadian retailer of AROMAR fragrance products, with fast shipping anywhere in Canada.' },
  { q: 'How fast is shipping within Canada?', a: 'Orders ship quickly from within Canada through Amazon — no slow cross-border wait and no surprise customs fees. Delivery is typically 2–7 business days; exact options are shown at checkout.' },
  { q: 'Are Oopsie Poopsie and AROMAR+ made in the USA?', a: 'Yes. Both product lines are manufactured by AROMAR in the USA from premium fragrance oils. We are an independent Canadian retailer making them available to Canadian customers with local shipping.' },
  { q: 'Can I use Oopsie Poopsie in a public restroom or rental?', a: 'Absolutely. The pocket-sized bottle slips into any bag or purse — discreetly spray into any toilet bowl before use to keep public restrooms, rentals and hotel rooms fresh. Poop anywhere with confidence.' },
  { q: 'Is AROMAR+ Spa Room Mist safe around pets?', a: 'AROMAR+ Spa Room Mist is generally safe when applied to surfaces or fabric (not directly on the pet). Let areas dry before pets contact them, and keep bottles out of reach of pets and children.' },
  { q: 'What is the Channel #5* inspired Spa Room Mist?', a: 'Our Channel #5* (type) Spa Room Mist is inspired by classic French perfumery — crafted to evoke the sophistication reminiscent of iconic luxury fragrances. It is an independent AROMAR+ fragrance and is not affiliated with, or endorsed by, any luxury brand.' },
];
---

<Layout
  title="Air Freshener Canada | Room Spray, Linen Mist & Toilet Spray"
  description="Shop natural air fresheners in Canada — AROMAR+ room sprays & linen mists for bedrooms, fabric and pillows, plus Oopsie Poopsie before-you-go toilet sprays. Essential-oil based, made in USA, fast Canadian shipping."
>
  <!-- NAVBAR -->
  <div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar w-nav">
    <div class="padding-global">
      <div class="container w-container">
        <div class="navbar-component">
          <a href="#" class="brand w-nav-brand"><img loading="lazy" src="/images/Logo-Spacekit.svg" alt="BRISE" class="logo-navbar" /></a>
          <div class="right-navbar-content">
            <div class="nav-menu-wrap">
              <div class="menu-button w-nav-button">
                <div class="menu-icon w-icon-nav-menu"></div>
              </div>
            </div>
            <nav role="navigation" class="nav-menu w-nav-menu">
              <a href="/" class="nav-link w-inline-block"><div>Home</div></a>
              <a href="#oopsie" class="nav-link w-inline-block"><div>Toilet Sprays</div></a>
              <a href="#room-mist" class="nav-link w-inline-block"><div>Room Mists</div></a>
              <a href="#faq" class="nav-link w-inline-block"><div>FAQ</div></a>
              <div class="button-border">
                <a href="#where-to-buy" class="button-navbar margin-left w-inline-block">
                  <div class="text-size-small">Contact Us</div>
                </a>
              </div>
            </nav>
          </div>
        </div>
      </div>
    </div>
    <div class="overlay-navbar"></div>
  </div>

  <!-- STICKY SECTION SWITCHER (appears after hero) -->
  <div class="sb-pillnav" id="sb-pillnav" aria-label="Jump to product line">
    <div class="sb-pillnav-inner">
      <a href="#oopsie" class="sb-pill" data-target="oopsie"><span class="sb-pill-dot"></span>Toilet Sprays</a>
      <a href="#room-mist" class="sb-pill" data-target="room-mist"><span class="sb-pill-dot"></span>Room Mists</a>
    </div>
  </div>

  <!-- HERO — split into two worlds -->
  <section class="sb-hero2">
    <div class="sb-hero2-intro">
      <div class="sb-hero2-eyebrow">BRISE · Premium Air Fresheners in Canada</div>
      <h1 class="sb-hero2-title">Two ways to make any space smell incredible.</h1>
      <p class="sb-hero2-sub">Made in the USA by AROMAR · shipped fast from Canada · essential-oil fragrance.</p>
    </div>
    <div class="sb-hero2-split">
      <a href="#oopsie" class="sb-hero2-panel sb-hero2-panel--op">
        <div class="sb-hero2-panel-num">01</div>
        <div class="sb-hero2-panel-body">
          <div class="sb-hero2-panel-kicker">Oopsie Poopsie</div>
          <div class="sb-hero2-panel-h">Before-You-Go Toilet Sprays</div>
          <p>Oil-based. Spray in the bowl before you go — odors are trapped at the source. 8 fragrances.</p>
          <span class="sb-hero2-panel-cta">Explore toilet sprays →</span>
        </div>
        <img class="sb-hero2-panel-img" src="/images/products/op-lemon-bergamot.webp" loading="eager" alt="Oopsie Poopsie before-you-go toilet spray" />
      </a>
      <a href="#room-mist" class="sb-hero2-panel sb-hero2-panel--rm">
        <div class="sb-hero2-panel-num">02</div>
        <div class="sb-hero2-panel-body">
          <div class="sb-hero2-panel-kicker">AROMAR+ Spa</div>
          <div class="sb-hero2-panel-h">Room &amp; Linen Mists</div>
          <p>Water-based &amp; fabric-safe. Mist rooms, bedding, couches and clothing. 8 oz · 10 fragrances.</p>
          <span class="sb-hero2-panel-cta">Explore room mists →</span>
        </div>
        <img class="sb-hero2-panel-img" src="/images/products/rm-white-gardenia.webp" loading="eager" alt="AROMAR+ Spa Room Mist room and linen spray" />
      </a>
    </div>
  </section>

  <!-- ============ WORLD 1 — OOPSIE POOPSIE ============ -->
  <section class="world world--op" id="oopsie">
    <div class="world-inner">
      <header class="world-header">
        <div class="world-num">01</div>
        <div class="world-head-text">
          <div class="world-kicker">Oopsie Poopsie · Toilet Spray</div>
          <h2 class="world-title">The before-you-go toilet spray</h2>
          <p class="world-tagline">Oil-based and made with essential oils. A few sprays into the bowl water <em>before</em> you go traps odors beneath the surface — at home, at work, anywhere there's a toilet.</p>
          <div class="world-trust"><span>Oil-based</span><span>·</span><span>Essential oils</span><span>·</span><span>Made in USA</span><span>·</span><span>8 fragrances</span></div>
        </div>
      </header>

      <!-- Products -->
      <div class="products-wrapper" id="products">
        <div class="products-header">
          <div class="products-heading">
            <div class="flex-horizontal">
              <div class="icon-wrapper"><img src="/images/Cross.svg" loading="lazy" alt="" /></div>
              <div class="text-size-large text-weight-medium caps">Shop the 8 scents</div>
            </div>
            <div class="opacity-60"><div>Pre-poop toilet sprays</div></div>
          </div>
          <div class="button-wrapper">
            <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="black-button w-inline-block">
              <div class="text-weight-medium caps">Shop on Amazon</div>
            </a>
          </div>
        </div>
        <div class="products-card-wrapper">
          <div role="list" class="products-cards">
            {oopsiePoopsie.map((p) => (
              <div role="listitem">
                <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="product-link w-inline-block">
                  <div class="product-card-image">
                    {p.image
                      ? <img src={p.image} loading="lazy" alt={`Oopsie Poopsie ${p.name} pre-poop toilet spray`} class="image" />
                      : <div class="sb-img-placeholder"><span>{p.name}</span><small>Photo coming soon</small></div>}
                  </div>
                  <div class="product-card-info">
                    <div class="info">
                      <div class="text-size-small text-weight-medium caps">{p.name}</div>
                      <div class="sb-scent-notes">{p.notes}</div>
                    </div>
                    <div class="buy-now-button">Buy Now →</div>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- How to use (full-width 3-step row) -->
      <div class="world-howto world-howto--row">
        <div class="world-subhead">How to use</div>
        <ol class="how-steps how-steps--row">
          <li><span class="how-step-n">1</span><div><h4>Spray before you go</h4><p>3–5 sprays directly onto the toilet bowl water before you sit down.</p></div></li>
          <li><span class="how-step-n">2</span><div><h4>Let the oil do the work</h4><p>It floats and forms an invisible barrier that traps odors beneath the surface.</p></div></li>
          <li><span class="how-step-n">3</span><div><h4>Flush as normal</h4><p>No lingering smell, no spray cloud. Pocket-sized, take it anywhere.</p></div></li>
        </ol>
      </div>

      <!-- Lifestyle carousel (Rivian-style) -->
      <div class="sb-carousel" data-carousel>
        <div class="sb-carousel-head">
          <div>
            <div class="world-subhead">Why you'll love it</div>
            <h3 class="sb-carousel-title">Get to know Oopsie Poopsie — the anti-awkward toilet spray.</h3>
          </div>
          <div class="sb-carousel-nav">
            <button type="button" class="sb-carousel-btn" data-dir="prev" aria-label="Previous slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></button>
            <button type="button" class="sb-carousel-btn" data-dir="next" aria-label="Next slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></button>
          </div>
        </div>
        <div class="sb-carousel-track" data-track>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-how.webp" loading="lazy" alt="How Oopsie Poopsie works — shake, spray the bowl, flush" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">How it works</span><span class="sb-slide-title">Spray. Poo. Flush.</span></div>
          </a>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-spray.webp" loading="lazy" alt="A hand spraying Oopsie Poopsie into a toilet bowl before use" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">Long-lasting</span><span class="sb-slide-title">Up to 300 sprays</span></div>
          </a>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-badges.webp" loading="lazy" alt="Oopsie Poopsie — made in the USA, essential oils, cruelty-free, aerosol-free" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">Why it's better</span><span class="sb-slide-title">Made in the USA</span></div>
          </a>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-flatlay.webp" loading="lazy" alt="Oopsie Poopsie Berry Fresh — winterberry and pine essential-oil toilet spray" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">Essential-oil scents</span><span class="sb-slide-title">8 bold fragrances</span></div>
          </a>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-box.webp" loading="lazy" alt="Oopsie Poopsie toilet spray lineup — a fragrance for every bathroom" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">The full lineup</span><span class="sb-slide-title">A scent for every bathroom</span></div>
          </a>
          <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-slide">
            <img src="/images/lifestyle/cr-bottle.webp" loading="lazy" alt="Pocket-sized Oopsie Poopsie toilet spray bottle" />
            <div class="sb-slide-cap"><span class="sb-slide-kicker">Pocket-sized</span><span class="sb-slide-title">Take it anywhere</span></div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WORLD 2 — AROMAR+ SPA ROOM MIST ============ -->
  <section class="world world--rm" id="room-mist">
    <div class="world-inner">
      <header class="world-header">
        <div class="world-num">02</div>
        <div class="world-head-text">
          <div class="world-kicker">AROMAR+ · Spa Room Mist</div>
          <h2 class="world-title">The room &amp; linen mist</h2>
          <p class="world-tagline">A water-based room spray and linen mist with essential-oil fragrance. Safe on fabric — no oily film, no staining. Spritz the air, your bedding, furniture and clothing. 8&nbsp;oz.</p>
          <div class="world-trust"><span>Water-based</span><span>·</span><span>Fabric-safe</span><span>·</span><span>8 oz</span><span>·</span><span>10 fragrances</span></div>
        </div>
      </header>

      <!-- Products -->
      <div class="products-wrapper">
        <div class="products-header">
          <div class="products-heading">
            <div class="flex-horizontal">
              <div class="icon-wrapper"><img src="/images/Cross.svg" loading="lazy" alt="" /></div>
              <div class="text-size-large text-weight-medium caps">Shop the 10 scents</div>
            </div>
            <div class="opacity-60"><div>Room &amp; fabric mists · 8 oz</div></div>
          </div>
          <div class="button-wrapper">
            <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="black-button w-inline-block">
              <div class="text-weight-medium caps">Shop on Amazon</div>
            </a>
          </div>
        </div>
        <div class="products-card-wrapper">
          <div role="list" class="products-cards">
            {roomMists.map((p) => (
              <div role="listitem">
                <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="product-link w-inline-block">
                  <div class="product-card-image">
                    {p.image
                      ? <img src={p.image} loading="lazy" alt={`AROMAR+ ${p.name} Spa Room Mist 8 oz`} class="image" />
                      : <div class="sb-img-placeholder"><span>{p.name}</span><small>Photo coming soon</small></div>}
                  </div>
                  <div class="product-card-info">
                    <div class="info">
                      <div class="text-size-small text-weight-medium caps">{p.name}{p.star ? ' (type)' : ''}</div>
                      <div class="sb-scent-notes">{p.notes}</div>
                    </div>
                    <div class="buy-now-button">Buy Now →</div>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </div>
        <p class="sb-star-disclaimer">* Channel #5 Inspired: experience the captivating allure of our Channel&nbsp;#5* (type) Room Mist, carefully crafted to evoke the sophistication reminiscent of the iconic fragrance. An independent AROMAR+ fragrance — not affiliated with or endorsed by any luxury brand.</p>
      </div>

      <!-- How to use + Where to use -->
      <div class="world-grid">
        <div class="world-howto">
          <div class="world-subhead">How to use</div>
          <ol class="how-steps">
            <li><span class="how-step-n">1</span><div><h4>Mist the air &amp; fabric</h4><p>A few sprays over the room, bedding, couch, curtains or clothing.</p></div></li>
            <li><span class="how-step-n">2</span><div><h4>Let it settle</h4><p>The water-based formula dries clean — no oily residue, no staining.</p></div></li>
            <li><span class="how-step-n">3</span><div><h4>Refresh anytime</h4><p>Reapply on linen and upholstery; the scent holds for days.</p></div></li>
          </ol>
        </div>
        <div class="world-uses">
          <div class="world-subhead">Where to use</div>
          <div class="sb-uses-grid">
            <div class="sb-use-card">
              <div class="sb-use-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 17V7a1 1 0 0 1 1-1h11a3 3 0 0 1 3 3v3"/><path d="M2 13h18a2 2 0 0 1 2 2v2"/><path d="M2 17v2M22 17v2"/></svg></div>
              <h4>Bedroom &amp; Linen</h4><p>Mist pillows, sheets and mattresses for spa-like sleep.</p>
            </div>
            <div class="sb-use-card">
              <div class="sb-use-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M2 13a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5H2z"/><path d="M5 18v2M19 18v2"/></svg></div>
              <h4>Living Room &amp; Fabric</h4><p>Refresh couches, curtains and rugs in seconds.</p>
            </div>
            <div class="sb-use-card">
              <div class="sb-use-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4a2 2 0 1 0-1.7 3L3 13h18l-7.3-6A2 2 0 0 0 12 4z"/><path d="M3 13v3a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-3"/></svg></div>
              <h4>Closets &amp; Clothing</h4><p>Keep wardrobes, drawers and gym bags fresh for days.</p>
            </div>
            <div class="sb-use-card">
              <div class="sb-use-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6.5" cy="10.5" r="1.8"/><circle cx="10.5" cy="6.5" r="1.8"/><circle cx="13.5" cy="6.5" r="1.8"/><circle cx="17.5" cy="10.5" r="1.8"/><path d="M8 15.5c1.2-1.6 6.8-1.6 8 0 .9 1.2-.6 3-2.2 3-1 0-1.2-.6-1.8-.6s-.8.6-1.8.6c-1.6 0-3.1-1.8-2.2-3z"/></svg></div>
              <h4>Pets &amp; Whole Home</h4><p>A pet-friendly essential-oil freshener for every room.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHERE TO BUY + FAQ + FINAL CTA -->
  <section>
    <div class="padding-global">
      <div class="w-layout-blockcontainer container small w-container">
        <div class="sb-wtb-section" id="where-to-buy">
          <div class="sb-wtb-inner">
            <div class="sb-wtb-eyebrow">● Available across Canada</div>
            <h2 class="sb-wtb-heading">Where to Buy Oopsie Poopsie &amp; AROMAR Room Mists in Canada</h2>
            <p class="sb-wtb-body">Buy <strong>Oopsie Poopsie pre-poop toilet sprays</strong> and <strong>AROMAR+ Spa Room Mists</strong> online in Canada. 8 toilet-spray fragrances and 10 room-and-fabric mists, all made in the USA by AROMAR, sold through our Amazon Canada storefront. Ships from within Canada with no customs fees and Amazon buyer-guarantee returns.</p>
            <div class="sb-wtb-trust"><span>✓ Made in USA</span><span class="sb-wtb-dot"></span><span>✓ Ships from Canada</span><span class="sb-wtb-dot"></span><span>✓ 18 fragrances</span><span class="sb-wtb-dot"></span><span>✓ Verified Amazon storefront</span></div>
            <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="sb-wtb-cta">Shop on Amazon Canada →</a>
          </div>
        </div>

        <div class="faq-wrapper" id="faq">
          <div class="faq-heading">
            <div class="heading-5">FAQ: Pre-Poop Toilet Sprays &amp; Spa Room Mists</div>
          </div>
          <div class="faq-component">
            <div role="list" class="faq-list">
              {faqs.map((f) => (
                <div role="listitem" class="faq-hover">
