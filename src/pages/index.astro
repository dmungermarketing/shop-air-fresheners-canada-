  <!-- Carousel interactions: prev/next + button disabled state -->
  <script is:inline>
    (function () {
      function initWorlds() {
        // Carousels: prev/next buttons scroll the track by one slide
        document.querySelectorAll('[data-carousel]').forEach(function (car) {
          var track = car.querySelector('[data-track]');
          if (!track) return;
          function step() {
            var slide = track.querySelector('.sb-slide');
            var gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '16') || 16;
            return slide ? slide.getBoundingClientRect().width + gap : track.clientWidth * 0.8;
          }
          car.querySelectorAll('[data-dir]').forEach(function (btn) {
            btn.addEventListener('click', function () {
              track.scrollBy({ left: (btn.getAttribute('data-dir') === 'next' ? 1 : -1) * step(), behavior: 'smooth' });
            });
          });
          function updateBtns() {
            var prev = car.querySelector('[data-dir="prev"]');
            var next = car.querySelector('[data-dir="next"]');
            var max = track.scrollWidth - track.clientWidth - 2;
            if (prev) prev.disabled = track.scrollLeft <= 2;
            if (next) next.disabled = track.scrollLeft >= max;
          }
          track.addEventListener('scroll', updateBtns, { passive: true });
          updateBtns();
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWorlds);
      } else {
        initWorlds();
      }
    })();
  </script>
