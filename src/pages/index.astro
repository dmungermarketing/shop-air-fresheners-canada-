          />
          <img
            src="/images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2.webp"
            loading="eager"
            fetchpriority="high"
            sizes="100vw"
            srcset="/images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2-p-500.webp 500w, /images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2-p-800.webp 800w, /images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2-p-1080.webp 1080w, /images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2-p-1600.webp 1600w, /images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2.webp 1792w"
            alt="Scent Bomb air freshener sprays — all 9 fragrances available in Canada"
