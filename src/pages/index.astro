                            <path d="M12 2.5c-3.5 4.5-7 8.5-7 13a7 7 0 0 0 14 0c0-4.5-3.5-8.5-7-13z"/>
                            <path d="M8.5 15.5c0 1.8 1.4 3.2 3.2 3.2" opacity="0.45"/>
