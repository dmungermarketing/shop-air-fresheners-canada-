---
import Layout from '../layouts/Layout.astro';

// PLACEHOLDER — replace with your real Amazon storefront URL before publishing
const AMAZON_URL = 'https://www.amazon.ca/REPLACE-WITH-YOUR-STOREFRONT';

const products = [
  { name: 'Black Cherry', image: '/images/black-cherry.webp', bestSeller: true },
  { name: 'Mango Tropical', image: '/images/mango-tropical.webp', bestSeller: true },
  { name: 'Hawaiian Blue', image: '/images/hawaiian-blue.webp', bestSeller: true },
  { name: 'Clean Cotton', image: '/images/clean-cotton.webp', bestSeller: true },
  { name: 'Vanilla', image: '/images/vanilla.webp', bestSeller: false },
  { name: 'Green Bomb', image: '/images/green-bomb.webp', bestSeller: false },
  { name: 'Juicy Juice', image: '/images/juicy-juice.webp', bestSeller: false },
  { name: 'Tangerine Blast', image: '/images/tangerine-blast.webp', bestSeller: false },
  { name: 'New Car', image: '/images/new-car.webp', bestSeller: false },
];

const faqs = [
  { q: 'Is Scent Bomb really made in the USA?', a: 'Yes. Scent Bomb is made in the USA from 100% pure fragrance oil. We are an independent Canadian seller making the full lineup available to Canadian customers with local shipping.' },
  { q: 'How fast is shipping within Canada?', a: 'Orders ship quickly from within Canada — no slow cross-border wait and no customs fees. Delivery times and any options are shown at checkout.' },
  { q: 'Where can I buy Scent Bomb in Canada?', a: 'Right here. Click any "Shop Scent Bomb" button and you will be taken to our storefront to complete your order, with fast shipping anywhere in Canada.' },
  { q: 'Can Scent Bomb help with smelly sports equipment?', a: 'It is great for keeping gym bags, lockers and shoes fresh between uses — Clean Cotton is the favourite for this. For heavily used gear like hockey or football pads, use it to manage odor day-to-day, alongside an occasional deep clean.' },
  { q: 'Will Scent Bomb leave an oily residue?', a: 'Only if it is used incorrectly. Sprayed onto fabric, mats, cotton balls or the inside of containers — as intended — there is no issue. Avoid spraying it directly onto hard floors or walkable surfaces.' },
  { q: 'Is Scent Bomb good for travel?', a: 'Yes — it is one of the most travel-friendly air fresheners out there. The 1 oz bottle is small enough for a pocket, purse, glove box or carry-on, so you can freshen a hotel room, a rental car or a friend’s place in seconds.' },
  { q: 'How much does one bottle cover?', a: 'A couple of sprays handle a car interior or a small bathroom. For larger rooms, a spray or two in each corner does it. The 1 oz bottle lasts a long time in a single space; the 8 oz XL covers a whole house and refills your smaller bottles.' },
  { q: 'Does Scent Bomb eliminate odors or just cover them?', a: 'Because it is so concentrated, Scent Bomb overpowers an odor rather than faintly layering over it — especially when you apply it at the source of the smell. For best results, spray where the odor is actually coming from.' },
  { q: 'How do I use Scent Bomb spray for the best results?', a: 'Hold the bottle 1–2 inches from a surface and apply 1–2 sprays — onto a floor mat, under a seat, inside a bin, or onto a cotton ball. Don’t spray it into the air: it’s pure oil and can leave a slippery film on hard surfaces. A little goes a long way.' },
  { q: 'How long does Scent Bomb last?', a: 'Because it is concentrated fragrance oil, a single application typically keeps a small space fresh all day and often into the next. A cotton ball sprayed once can hold its scent for several days.' },
  { q: 'Which Scent Bomb fragrance should I choose?', a: 'It depends on the space. Black Cherry and Mango Tropical are bold and popular for cars. Vanilla is the warm, safe choice for shared spaces. Clean Cotton is the most neutral and versatile — ideal for gym bags, bathrooms and offices. Green Bomb is the pick for a crisp, masculine scent.' },
  { q: 'Is Scent Bomb safe to use in my car?', a: 'Yes — apply it to the floor mat, under a seat, or onto a cotton ball. Avoid the dashboard, pedals and steering wheel: the oil can be slippery on hard surfaces you touch or step on.' },
  { q: 'Can I use Scent Bomb in the toilet?', a: 'Yes, and it works well. Spray 3–4 sprays directly onto the water in the bowl. The oil floats and forms a thin barrier across the surface that helps trap odors before they rise into the room — keeping the bathroom fresh before and after use.' },
];
---

<Layout
