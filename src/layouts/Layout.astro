      /* WORLD sections — themed via CSS vars */
      .world { padding: clamp(3.5rem, 7vw, 6rem) 1.5rem; scroll-margin-top: 80px; }
      .world--op {
        --w-accent: #C8732F; --w-accent-deep: #9d551d; --w-soft: rgba(200,115,47,0.1);
        background:
          radial-gradient(circle at 12% 0%, rgba(200,115,47,0.07), transparent 40%),
          linear-gradient(180deg, #FBF6EC 0%, #FBF6EC 100%);
      }
      .world--rm {
        --w-accent: #0F766E; --w-accent-deep: #134E4A; --w-soft: rgba(15,118,110,0.1);
        background:
          radial-gradient(circle at 88% 0%, rgba(15,118,110,0.07), transparent 40%),
          linear-gradient(180deg, #EAF1F1 0%, #EFF4F4 100%);
