      .world-inner { max-width: 1180px; margin: 0 auto; }
      .world-header { display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2.5rem; }
      .world-num {
        font-family: "Montserrat", sans-serif; font-weight: 900;
