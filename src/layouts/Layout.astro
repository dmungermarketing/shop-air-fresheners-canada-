      /* RIVIAN-STYLE CAROUSEL (mobile-first horizontal scroll-snap) */
      .sb-carousel { margin-top: 3.25rem; }
      .sb-carousel-head {
        display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem;
        margin-bottom: 1.25rem;
      }
      .sb-carousel-title {
        font-family: "Montserrat", sans-serif; font-weight: 800; letter-spacing: -0.02em;
        font-size: clamp(1.2rem, 2.4vw, 1.6rem); line-height: 1.2; color: #18211f;
        margin: 0; max-width: 30ch;
      }
      .sb-carousel-nav { display: flex; gap: 0.5rem; flex: 0 0 auto; }
      .sb-carousel-btn {
        width: 44px; height: 44px; border-radius: 50%;
