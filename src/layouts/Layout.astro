  <body>
    <slot />

    <!-- jQuery + Webflow JS for interactions (hover effects, lightbox, etc.) -->
    <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js" type="text/javascript"></script>
    <script src="/js/webflow.js" type="text/javascript"></script>

    <!-- BRISE custom JS: anchor wiring + smooth scroll -->
    <script is:inline>
      (function() {
        function initBrise() {
          // 1. Copyright cleanup
          const copyP = document.querySelector('.credits-wrapper p:first-child');
          if (copyP && copyP.textContent.trim() === 'Copyright ©') {
            copyP.textContent = '©';
          }
          // 2. ADD anchor IDs
          const faqWrap = document.querySelector('.faq-wrapper');
          if (faqWrap && !faqWrap.id) { faqWrap.id = 'faq'; }
          const productsSection = document.querySelector('.products-wrapper');
          if (productsSection && !productsSection.id) { productsSection.id = 'products'; }
          const wtbSection = document.querySelector('.sb-wtb-section');
          if (wtbSection && !wtbSection.id) { wtbSection.id = 'where-to-buy'; }
          // 3. NAV LINK ANCHOR redirects
          document.querySelectorAll('a.nav-link[href="/products"], a.footer-link[href="/products"]').forEach(function(link) {
            link.setAttribute('href', '#products');
          });
          document.querySelectorAll('a.nav-link[href="/faq"], a.footer-link[href="/faq"]').forEach(function(link) {
            link.setAttribute('href', '#faq');
          });
          // 4. BUY button → #where-to-buy
          const buyBtn = document.querySelector('.button-navbar');
          if (buyBtn) {
            buyBtn.setAttribute('href', '#where-to-buy');
            buyBtn.removeAttribute('target');
            buyBtn.removeAttribute('rel');
          }
          // 5. Brand BRISE logo → scroll top
          const brandLink = document.querySelector('a.brand');
          if (brandLink) {
            brandLink.setAttribute('href', '#');
            brandLink.removeAttribute('aria-current');
            brandLink.addEventListener('click', function(e) {
              e.preventDefault();
              window.scrollTo({ top: 0, behavior: 'smooth' });
            });
          }
          // 6. Smooth scroll with navbar offset
          document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
            anchor.addEventListener('click', function(e) {
              const targetId = this.getAttribute('href');
              if (targetId === '#' || targetId.length < 2) return;
              const target = document.querySelector(targetId);
              if (target) {
                e.preventDefault();
                const navbarHeight = window.innerWidth >= 992 ? 110 : (window.innerWidth >= 768 ? 90 : 80);
                const targetTop = target.getBoundingClientRect().top + window.pageYOffset - navbarHeight;
                window.scrollTo({ top: targetTop, behavior: 'smooth' });
              }
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initBrise);
        } else {
          initBrise();
        }
      })();
    </script>
  </body>
