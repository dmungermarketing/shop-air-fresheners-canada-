        color: var(--w-accent); opacity: 0.28; flex: 0 0 auto;
      }
      .world-kicker {
        font-family: "Montserrat", sans-serif; font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.16em; text-transform: uppercase; color: var(--w-accent); margin-bottom: 0.5rem;
      }
      .world-title {
        font-family: "Montserrat", sans-serif; font-weight: 900; letter-spacing: -0.03em;
        font-size: clamp(1.9rem, 4vw, 3rem); line-height: 1.05; color: #18211f; margin: 0 0 0.85rem;
      }
      .world-tagline {
        font-family: "Montserrat", sans-serif; font-size: 1rem; line-height: 1.6;
        color: #4f5b5a; margin: 0 0 1rem; max-width: 60ch;
      }
      .world-tagline em { color: var(--w-accent-deep); font-style: italic; }
      .world-trust {
        display: flex; flex-wrap: wrap; gap: 0.6rem; align-items: center;
        font-family: "Montserrat", sans-serif; font-size: 0.78rem; font-weight: 600;
        letter-spacing: 0.04em; color: var(--w-accent-deep);
      }
      .world-trust span:nth-child(even) { opacity: 0.4; }

      /* tint product accents + shop buttons per world */
      .world .icon-wrapper img { filter: none; }
      .world .black-button { background-color: var(--w-accent) !important; transition: background-color 0.3s ease; }
      .world .black-button:hover { background-color: var(--w-accent-deep) !important; }
      .world .buy-now-button { color: var(--w-accent-deep); }
      .world .sb-img-placeholder {
        background: radial-gradient(circle at 30% 25%, color-mix(in srgb, var(--w-accent) 45%, transparent), transparent 55%),
                    linear-gradient(135deg, var(--w-accent-deep) 0%, var(--w-accent) 100%);
      }

      /* how-to + where-to-use grid inside a world */
      .world-grid {
