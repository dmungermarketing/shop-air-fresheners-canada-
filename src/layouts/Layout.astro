---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Oopsie Poopsie Canada | Before-You-Go Toilet Spray',
  description = 'Buy Oopsie Poopsie pre-poop toilet spray in Canada — spray the bowl before you go to trap odors at the source. 8 essential-oil scents, made in USA, fast Canadian shipping.',
  canonical = Astro.url.href,
} = Astro.props;

const SITE_URL = 'https://www.shopairfresheners.ca';
const OG_IMAGE = `${SITE_URL}/images/og-image.webp`;
const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

// PLACEHOLDER — replace with the real Amazon storefront URL before publishing
const AMAZON_URL = 'https://www.amazon.ca/REPLACE-WITH-YOUR-STOREFRONT';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How does Oopsie Poopsie pre-poop toilet spray work?', acceptedAnswer: { '@type': 'Answer', text: 'Spray 3 to 5 times directly into the toilet bowl water BEFORE you go. The oil-based formula floats on the water surface and forms an invisible barrier that traps odors before they rise into the room. The bathroom stays fresh.' } },
    { '@type': 'Question', name: 'How many sprays of Oopsie Poopsie should I use?', acceptedAnswer: { '@type': 'Answer', text: 'For best results, 3 to 5 sprays directly into the toilet bowl water before sitting down. The oil forms a thin floating layer that traps odors. A little goes a long way — one bottle lasts hundreds of uses.' } },
    { '@type': 'Question', name: 'Which Oopsie Poopsie fragrance should I choose?', acceptedAnswer: { '@type': 'Answer', text: 'Popular picks: Lemon Bergamot (bright citrus), Lavender Escape (calming, classic), Mediterranean Sage (earthy, herbal), Berry Fresh (sweet, fruity), Morning Shower (clean rose and powder), and Flower Citrus (uplifting floral). All 8 are made with essential oils — pick what suits your home best.' } },
    { '@type': 'Question', name: 'Is Oopsie Poopsie made with essential oils?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Oopsie Poopsie is made in the USA with essential oils — aerosol-free and cruelty-free. The concentrated formula means a little goes a long way.' } },
    { '@type': 'Question', name: 'Can I use Oopsie Poopsie in a public restroom or rental?', acceptedAnswer: { '@type': 'Answer', text: 'Absolutely. The pocket-sized bottle slips into any bag or purse. Discreetly spray into any toilet bowl before use to keep public restrooms, rental units and hotel rooms fresh.' } },
    { '@type': 'Question', name: 'Where can I buy Oopsie Poopsie toilet spray in Canada?', acceptedAnswer: { '@type': 'Answer', text: 'Right here. Click any Shop button to order. We are an independent Canadian retailer of Oopsie Poopsie, with fast shipping anywhere in Canada.' } },
    { '@type': 'Question', name: 'How fast is shipping within Canada?', acceptedAnswer: { '@type': 'Answer', text: 'Orders ship quickly from within Canada — no slow cross-border wait and no surprise customs fees. Delivery is typically 2 to 7 business days; exact options are shown at checkout.' } },
    { '@type': 'Question', name: 'Is Oopsie Poopsie really made in the USA?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Oopsie Poopsie is manufactured in the USA from premium essential oils. We are an independent Canadian retailer making it available to Canadian customers with local shipping.' } },
  ],
};

const oopsiePoopsieScents = ['Lemon Bergamot', 'Lavender Escape', 'Mediterranean Sage', 'Berry Fresh', 'Morning Shower', 'Flower Citrus', 'Summer Sea', 'Wild Mint'];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${SITE_URL}/#product`,
  name: 'Oopsie Poopsie Pre-Poop Toilet Spray',
  alternateName: ['Oopsie Poopsie', 'Oopsie Poopsie Toilet Spray', 'Pre-Poop Toilet Spray', 'Before-You-Go Toilet Spray'],
  description: 'Buy Oopsie Poopsie pre-poop toilet spray in Canada — oil-based, made with essential oils. Spray the bowl before you go and odors are trapped at the source. 8 fragrances: Lemon Bergamot, Lavender Escape, Mediterranean Sage, Berry Fresh, Morning Shower, Flower Citrus, Summer Sea and Wild Mint. Made in USA, shipped from Canada.',
  category: 'Air Fresheners > Anti-Odor Toilet Sprays',
  image: [OG_IMAGE],
  brand: { '@type': 'Brand', name: 'Oopsie Poopsie' },
  manufacturer: { '@type': 'Organization', name: 'AROMAR', address: { '@type': 'PostalAddress', addressCountry: 'US' } },
  countryOfOrigin: { '@type': 'Country', name: 'US' },
  keywords: 'oopsie poopsie canada, pre poop toilet spray, before you go toilet spray, poop spray, toilet spray, bathroom deodorizer, essential oil toilet spray',
  offers: {
    '@type': 'AggregateOffer',
    offerCount: 8,
    priceCurrency: 'CAD',
    lowPrice: '12.99',
    highPrice: '12.99',
    availability: 'https://schema.org/InStock',
    seller: { '@id': `${SITE_URL}/#organization` },
    url: AMAZON_URL,
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'BRISE',
  alternateName: 'Shop Air Fresheners Canada',
  description: 'Independent Canadian retailer of Oopsie Poopsie pre-poop toilet sprays.',
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  image: OG_IMAGE,
  areaServed: { '@type': 'Country', name: 'Canada' },
  sameAs: [AMAZON_URL],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  url: SITE_URL,
  name: 'Shop Air Fresheners Canada',
  description: 'Shop Oopsie Poopsie pre-poop toilet spray in Canada. 8 essential-oil scents, made in USA, fast Canadian shipping.',
  inLanguage: 'en-CA',
  publisher: { '@id': `${SITE_URL}/#organization` },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'OnlineStore',
  '@id': `${SITE_URL}/#store`,
  name: 'Shop Air Fresheners Canada — Oopsie Poopsie',
  description: 'Online Canadian retailer of Oopsie Poopsie pre-poop toilet sprays — 8 essential-oil fragrances, oil-based, made in the USA. Fast Canadian shipping.',
  url: SITE_URL,
  image: OG_IMAGE,
  currenciesAccepted: 'CAD',
  areaServed: { '@type': 'Country', name: 'Canada' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Oopsie Poopsie Pre-Poop Toilet Sprays — 8 Fragrances',
    itemListElement: oopsiePoopsieScents.map((scent, i) => ({
      '@type': 'Offer',
      name: `Oopsie Poopsie ${scent} — Pre-Poop Toilet Spray`,
      description: `Oopsie Poopsie ${scent} — oil-based pre-poop toilet spray. Spray into the bowl water before use; the oil floats and traps odors before they rise. Made in USA, shipped from Canada.`,
      priceCurrency: 'CAD',
      price: '12.99',
      availability: 'https://schema.org/InStock',
      position: i + 1,
      url: AMAZON_URL,
      seller: { '@id': `${SITE_URL}/#organization` },
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
  ],
};
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Indexing & crawler hints -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <!-- Author / Publisher -->
    <meta name="author" content="BRISE — Independent Canadian Retailer" />
    <meta name="publisher" content="BRISE" />

    <!-- Geo targeting (Canada) -->
    <meta name="geo.region" content="CA" />
    <meta name="geo.placename" content="Canada" />
    <meta name="ICBM" content="56.1304, -106.3468" />

    <!-- Theme & app -->
    <meta name="theme-color" content="#0F766E" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#134E4A" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Shop Air Fresheners" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Keywords (Semrush CA/EN — toilet-spray / pre-poop cluster) -->
    <meta name="keywords" content="oopsie poopsie, oopsie poopsie canada, oopsie poopsie toilet spray, toilet spray, toilet spray canada, before you go toilet spray, before-you-go spray, pre poop toilet spray, pre poop spray, poop spray, poop spray for toilet, poo spray, bathroom spray, bathroom freshener, bathroom air freshener, bathroom deodorizer, toilet odor eliminator, toilet smell eliminator, toilet deodorizer spray, toilet odor spray, natural toilet spray, essential oil toilet spray, best toilet spray, air freshener for bathroom, toilet freshener, poop odor spray, made in usa toilet spray" />

    <!-- Open Graph (Facebook, LinkedIn, Pinterest) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:locale:alternate" content="fr_CA" />
    <meta property="og:site_name" content="Shop Air Fresheners Canada" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:secure_url" content={OG_IMAGE} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content="Oopsie Poopsie pre-poop toilet spray — 8 essential-oil scents, available in Canada" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content="Oopsie Poopsie pre-poop toilet spray — available in Canada" />
    <meta name="twitter:domain" content="shopairfresheners.ca" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#0F766E" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- DNS prefetch + preconnect (perf) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.amazon.ca" />
    <link rel="preconnect" href="https://d3e54v103j8qbb.cloudfront.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.amazon.ca" />

    <!-- Hero is now a CSS gradient (no LCP image to preload). Product images lazy-load below the fold. -->

    <!-- Webflow CSS -->
    <link href="/css/normalize.css" rel="stylesheet" type="text/css" />
    <link href="/css/webflow.css" rel="stylesheet" type="text/css" />
    <link href="/css/scent-bomb-air-fresheners.webflow.css" rel="stylesheet" type="text/css" />

    <!-- Google Fonts (Montserrat for BRISE branding + body) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&family=Montserrat+Alternates:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- BRISE Custom Styles (carried over from Webflow custom code) -->
    <style is:global>
      :root {
        --brise-teal: #0F766E;
        --brise-teal-deep: #134E4A;
        --brise-cream: #F5F1E8;
        --brise-teal-soft: rgba(15, 118, 110, 0.04);
      }

      html { scroll-behavior: smooth; scroll-padding-top: 110px; }
      /* Contain full-bleed sections (margin:-50vw hack) so they never create horizontal scroll — mobile-first */
      html, body { overflow-x: clip; max-width: 100%; }

      /* NAVBAR STICKY — floating with breathing room at top */
      body > .navbar,
      .navbar,
      .navbar.w-nav,
      div.navbar.w-nav {
        position: fixed !important;
        top: 1rem !important;
        left: 0 !important;
        right: 0 !important;
        width: 100% !important;
        z-index: 9999 !important;
        background-color: transparent !important;
      }
      .navbar-component {
        backdrop-filter: blur(14px) !important;
        -webkit-backdrop-filter: blur(14px) !important;
        background-color: rgba(245, 241, 232, 0.88) !important;
        transition: all 0.3s ease !important;
        padding: 0.85rem 1.5rem !important;
        overflow: visible !important;
        align-items: center !important;
      }
      .navbar .right-navbar-content,
      .navbar .nav-menu,
      .navbar .button-border { align-items: center !important; }
      @media (max-width: 767px) {
        body > .navbar,
        .navbar,
        .navbar.w-nav,
        div.navbar.w-nav {
          top: 0.5rem !important;
        }
      }

      /* WHERE TO USE — two product blocks */
      .sb-uses-block {
        margin-top: 2.5rem;
        padding: 2rem;
        border-radius: 20px;
        border: 1px solid rgba(15,118,110,0.12);
        background: linear-gradient(180deg, rgba(15,118,110,0.035), rgba(15,118,110,0) 60%);
      }
      .sb-uses-block--op { border-left: 4px solid #0F766E; }
      .sb-uses-block--rm { border-left: 4px solid #134E4A; }
      .sb-uses-head {
        display: flex;
        align-items: center;
        gap: 1.75rem;
        margin-bottom: 1.75rem;
      }
      .sb-uses-media {
        flex: 0 0 auto;
        width: 130px;
        height: 130px;
        border-radius: 16px;
        background: linear-gradient(160deg, #ffffff 0%, #eef4f4 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem;
        box-shadow: 0 10px 28px rgba(15,118,110,0.12);
      }
      .sb-uses-media img { max-width: 100%; max-height: 100%; object-fit: contain; }
      .sb-uses-intro { flex: 1; }
      .sb-uses-tag {
        font-family: "Montserrat", sans-serif;
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--brise-teal);
        margin-bottom: 0.5rem;
      }
      .sb-uses-intro h3 {
        font-family: "Montserrat", sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #1a1a1a;
        margin: 0 0 0.5rem;
        line-height: 1.15;
      }
      .sb-uses-intro p {
        font-family: "Montserrat", sans-serif;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #5a5a5a;
        margin: 0 0 0.9rem;
        max-width: 60ch;
      }
      .sb-uses-cta {
        display: inline-block;
        font-family: "Montserrat", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 0.7rem 1.4rem;
        border-radius: 999px;
        color: var(--brise-cream) !important;
        background: var(--brise-teal);
        transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
        box-shadow: 0 8px 22px rgba(15,118,110,0.3);
      }
      .sb-uses-cta:hover { background: var(--brise-teal-deep); transform: translateY(-2px); box-shadow: 0 12px 28px rgba(15,118,110,0.45); }
      .sb-uses-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      .sb-use-card {
        background: var(--bg-card, #fff);
        border: 1px solid rgba(15,118,110,0.1);
        border-radius: 14px;
        padding: 1.4rem 1.25rem;
        transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .sb-use-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 32px rgba(15,118,110,0.12);
        border-color: rgba(15,118,110,0.28);
      }
      .sb-use-icon {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: rgba(15,118,110,0.1);
        color: var(--brise-teal);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 0.85rem;
      }
      .sb-use-icon svg { width: 22px; height: 22px; }
      .sb-use-card h4 {
        font-family: "Montserrat", sans-serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: #1a1a1a;
        margin: 0 0 0.35rem;
      }
      .sb-use-card p {
        font-family: "Montserrat", sans-serif;
        font-size: 0.84rem;
        line-height: 1.5;
        color: #6a6a6a;
        margin: 0;
      }
      @media (max-width: 991px) {
        .sb-uses-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 600px) {
        .sb-uses-head { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .sb-uses-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
        .sb-uses-block { padding: 1.5rem 1.25rem; }
        .sb-use-card { padding: 1.1rem 1rem; }
      }
      @media (max-width: 400px) {
        .sb-uses-grid { grid-template-columns: 1fr; }
      }

      /* PRODUCT CARD — scent notes under the name */
      .sb-scent-notes {
        font-family: "Montserrat", sans-serif !important;
        font-size: 0.72rem !important;
        font-weight: 400 !important;
        letter-spacing: 0.01em !important;
        color: #6B6B73 !important;
        text-transform: none !important;
        margin-top: 0.25rem !important;
        line-height: 1.35 !important;
      }

      /* PRODUCT CARD — gradient placeholder for scents without a photo yet */
      .sb-img-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        text-align: center;
        padding: 1rem;
        background: radial-gradient(circle at 30% 25%, rgba(15,118,110,0.35), transparent 55%),
                    linear-gradient(135deg, #134E4A 0%, #0F766E 100%);
        color: var(--brise-cream);
      }
      .sb-img-placeholder span {
        font-family: "Montserrat", sans-serif;
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: -0.01em;
        line-height: 1.1;
      }
      .sb-img-placeholder small {
        font-family: "Montserrat", sans-serif;
        font-weight: 500;
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        opacity: 0.7;
      }

      /* STAR DISCLAIMER under room mist grid */
      .sb-star-disclaimer {
        font-family: "Montserrat", sans-serif;
        font-size: 0.72rem;
        line-height: 1.5;
        color: #8a8a8a;
        max-width: 70ch;
        margin: 1.5rem 0 0;
        font-style: italic;
      }

      /* ============ TWO WORLDS ============ */

      /* Sticky pill section-switcher */
      .sb-pillnav {
        position: fixed;
        top: 5.25rem;
        left: 50%;
        transform: translate(-50%, -12px);
        z-index: 9998;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.16,1,0.3,1);
      }
      .sb-pillnav.is-visible { opacity: 1; transform: translate(-50%, 0); pointer-events: auto; }
      .sb-pillnav-inner {
        display: flex;
        gap: 0.25rem;
        padding: 0.3rem;
        border-radius: 999px;
        background: rgba(245,241,232,0.82);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: 0 10px 30px rgba(19,78,74,0.18), 0 0 0 1px rgba(15,118,110,0.12);
      }
      .sb-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 1.1rem;
        border-radius: 999px;
        font-family: "Montserrat", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: var(--brise-teal-deep);
        transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
      }
      .sb-pill-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; opacity: 0.5; transition: all 0.3s ease; }
      .sb-pill:hover { background: rgba(15,118,110,0.1); }
      .sb-pill.is-active { background: var(--brise-teal); color: var(--brise-cream); box-shadow: 0 6px 16px rgba(15,118,110,0.4); }
      .sb-pill.is-active .sb-pill-dot { opacity: 1; }
      @media (max-width: 767px) {
        .sb-pillnav { top: auto; bottom: 1rem; }
        .sb-pill { padding: 0.5rem 0.9rem; font-size: 0.72rem; }
      }

      /* HERO — two worlds split */
      .sb-hero2 {
        background:
          radial-gradient(circle at 18% 18%, rgba(15,118,110,0.10), transparent 45%),
          radial-gradient(circle at 85% 12%, rgba(200,115,47,0.08), transparent 45%),
          var(--brise-cream);
        padding: 8rem 1.5rem 3.5rem;
      }
      .sb-hero2-intro { max-width: 1180px; margin: 0 auto 2.5rem; text-align: center; }

      /* HERO — single (Oopsie Poopsie) */
      .sb-hero2--solo { padding: 8rem 1.5rem 4rem; }
      .sb-hero2-solo-grid {
        max-width: 1100px; margin: 0 auto;
        display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.5rem; align-items: center;
      }
      .sb-hero2-intro--left { text-align: left; margin: 0; max-width: none; }
      .sb-hero2-intro--left .sb-hero2-title { margin-left: 0; }
      .sb-hero2-intro--left .sb-hero2-sub { margin-left: 0; }
      .sb-hero2-intro--left .sb-hero2-sub em { color: #b9701f; font-style: italic; }
      .sb-hero2-solo-cta {
        display: inline-block; margin-top: 1.5rem;
        font-family: "Montserrat", sans-serif; font-weight: 700; font-size: 0.9rem;
        padding: 1rem 2rem; border-radius: 999px;
        background: #C8732F; color: var(--brise-cream) !important;
        box-shadow: 0 12px 30px rgba(200,115,47,0.35);
        transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
      }
