---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Scent Bomb Canada | Buy Air Fresheners for Cars, Bathrooms',
  description = 'Buy Scent Bomb anti-odor air fresheners in Canada. Concentrated sprays for cars, bathrooms, toilets. 9 fragrances: Black Cherry, Vanilla, Hawaiian Blue & more. Fast Canadian shipping.',
  canonical = Astro.url.href,
} = Astro.props;

const SITE_URL = 'https://shopairfresheners.ca';
const OG_IMAGE = `${SITE_URL}/images/og-image.webp`;
const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

// PLACEHOLDER — replace with the real Amazon storefront URL before publishing
const AMAZON_URL = 'https://www.amazon.ca/REPLACE-WITH-YOUR-STOREFRONT';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I use Scent Bomb spray for the best results?', acceptedAnswer: { '@type': 'Answer', text: 'Hold the bottle 1 to 2 inches from a surface and apply 1 to 2 sprays onto a floor mat, under a seat, inside a bin, or onto a cotton ball. Do not spray it into the air: it is pure oil and can leave a slippery film on hard surfaces. A little goes a long way.' } },
    { '@type': 'Question', name: 'How long does Scent Bomb last?', acceptedAnswer: { '@type': 'Answer', text: 'Because it is concentrated fragrance oil, a single application typically keeps a small space fresh all day and often into the next. A cotton ball sprayed once can hold its scent for several days.' } },
    { '@type': 'Question', name: 'Which Scent Bomb fragrance should I choose?', acceptedAnswer: { '@type': 'Answer', text: 'It depends on the space. Black Cherry and Mango Tropical are bold and popular for cars. Vanilla and Black Bomb are warm, safe choices for shared spaces. Clean Cotton is the most neutral and versatile, ideal for gym bags, bathrooms and offices. Green Bomb is the pick for a crisp, masculine scent.' } },
    { '@type': 'Question', name: 'Is Scent Bomb safe to use in my car?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, apply it to the floor mat, under a seat, or onto a cotton ball. Avoid the dashboard, pedals and steering wheel: the oil can be slippery on hard surfaces you touch or step on.' } },
    { '@type': 'Question', name: 'Can I use Scent Bomb in the toilet?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, and it works well. Spray 3 to 4 sprays directly onto the water in the bowl. The oil floats and forms a thin barrier across the surface that helps trap odors before they rise into the room.' } },
    { '@type': 'Question', name: 'Does Scent Bomb eliminate odors or just cover them?', acceptedAnswer: { '@type': 'Answer', text: 'Because it is so concentrated, Scent Bomb overpowers an odor rather than faintly layering over it, especially when you apply it at the source of the smell.' } },
    { '@type': 'Question', name: 'How much does one bottle cover?', acceptedAnswer: { '@type': 'Answer', text: 'A couple of sprays handle a car interior or a small bathroom. For larger rooms, a spray or two in each corner does it. The 1 oz bottle lasts a long time in a single space; the 8 oz XL covers a whole house.' } },
    { '@type': 'Question', name: 'Is Scent Bomb good for travel?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, it is one of the most travel-friendly air fresheners out there. The 1 oz bottle is small enough for a pocket, purse, glove box or carry-on.' } },
    { '@type': 'Question', name: 'Will Scent Bomb leave an oily residue?', acceptedAnswer: { '@type': 'Answer', text: 'Only if it is used incorrectly. Sprayed onto fabric, mats, cotton balls or the inside of containers, as intended, there is no issue.' } },
    { '@type': 'Question', name: 'Can Scent Bomb help with smelly sports equipment?', acceptedAnswer: { '@type': 'Answer', text: 'It is great for keeping gym bags, lockers and shoes fresh between uses. Clean Cotton is the favourite for this.' } },
    { '@type': 'Question', name: 'Where can I buy Scent Bomb in Canada?', acceptedAnswer: { '@type': 'Answer', text: 'Right here. Click any Shop Scent Bomb button and you will be taken to our storefront to complete your order, with fast shipping anywhere in Canada.' } },
    { '@type': 'Question', name: 'How fast is shipping within Canada?', acceptedAnswer: { '@type': 'Answer', text: 'Orders ship quickly from within Canada, with no slow cross-border wait and no customs fees.' } },
    { '@type': 'Question', name: 'Is Scent Bomb really made in the USA?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Scent Bomb is made in the USA from 100% pure fragrance oil. We are an independent Canadian seller making the full lineup available to Canadian customers with local shipping.' } },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${SITE_URL}/#product`,
  name: 'Scent Bomb Concentrated Air Freshener Spray',
  alternateName: ['Scent Bomb', 'Scent Bomb Air Freshener', 'Scent Bomb Anti-Odor Spray', 'Scent Bomb Spray', 'Scent Bomb for Cars'],
  description: 'Buy Scent Bomb concentrated anti-odor air freshener spray in Canada. The most powerful 5-second odor eliminator for cars, bathrooms, toilets, gym bags, kitchens and homes. 100% pure fragrance oil. 9 fragrances available: Black Cherry, Mango Tropical, Hawaiian Blue, Clean Cotton, Vanilla, Green Bomb, Coconut Paradise, Tangerine Blast and New Car. 1 oz pocket size and 8 oz XL refill. Works as a pre-poop toilet spray, car air freshener and bathroom deodorant spray.',
  category: 'Air Fresheners > Concentrated Anti-Odor Sprays',
  image: [
    OG_IMAGE,
    `${SITE_URL}/images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers.webp`,
    `${SITE_URL}/images/black-cherry.webp`,
    `${SITE_URL}/images/mango-tropical.webp`,
    `${SITE_URL}/images/hawaiian-blue.webp`,
    `${SITE_URL}/images/clean-cotton.webp`,
  ],
  brand: { '@type': 'Brand', name: 'Scent Bomb' },
  manufacturer: { '@type': 'Organization', name: 'Scent Bomb', address: { '@type': 'PostalAddress', addressCountry: 'US' } },
  countryOfOrigin: { '@type': 'Country', name: 'US' },
  keywords: 'scent bomb canada, scent bomb spray, scent bomb for cars, scent bomb air freshener, anti-odor spray, toilet spray, bathroom spray, concentrated air freshener',
  offers: {
    '@type': 'AggregateOffer',
    offerCount: 9,
    priceCurrency: 'CAD',
    lowPrice: '14.99',
    highPrice: '39.99',
    availability: 'https://schema.org/InStock',
    seller: { '@id': `${SITE_URL}/#organization` },
    url: AMAZON_URL,
    // Shipping & return policy come from Amazon Canada's own listing — not declared here
    // (Amazon-managed; would mislead if we claim policies we don't control)
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'BRISE',
  alternateName: 'Shop Air Fresheners Canada',
  description: 'Independent Canadian retailer of Scent Bomb concentrated air fresheners.',
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  image: OG_IMAGE,
  areaServed: { '@type': 'Country', name: 'Canada' },
  sameAs: [AMAZON_URL],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  url: SITE_URL,
  name: 'Shop Air Fresheners Canada',
  description: 'Shop Scent Bomb concentrated air fresheners in Canada. 5-second odor elimination, 9 fragrances, fast Canadian shipping.',
  inLanguage: 'en-CA',
  publisher: { '@id': `${SITE_URL}/#organization` },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'OnlineStore',
  '@id': `${SITE_URL}/#store`,
  name: 'Shop Air Fresheners Canada — Scent Bomb Reseller',
  description: 'Online Canadian retailer specializing in Scent Bomb concentrated air freshener sprays. 9 fragrances available with fast Canadian shipping via Amazon storefront.',
  url: SITE_URL,
  image: OG_IMAGE,
  // Sales are fulfilled through Amazon Canada — they handle payment + shipping + returns
  currenciesAccepted: 'CAD',
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Scent Bomb Fragrance Collection — 9 Anti-Odor Air Freshener Sprays',
    itemListElement: [
      'Black Cherry', 'Mango Tropical', 'Hawaiian Blue', 'Clean Cotton',
      'Vanilla', 'Green Bomb', 'Coconut Paradise', 'Tangerine Blast', 'New Car'
    ].map((scent, i) => ({
      '@type': 'Offer',
      name: `Scent Bomb ${scent} Air Freshener Spray (1 oz)`,
      description: `Scent Bomb ${scent} — concentrated 1 oz anti-odor spray. Eliminates odors in 5 seconds. Shipped from Canada.`,
      priceCurrency: 'CAD',
      availability: 'https://schema.org/InStock',
      position: i + 1,
      url: AMAZON_URL,
      seller: { '@id': `${SITE_URL}/#organization` },
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
  ],
};
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Indexing & crawler hints -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <!-- Author / Publisher -->
    <meta name="author" content="BRISE — Independent Canadian Retailer" />
    <meta name="publisher" content="BRISE" />

    <!-- Geo targeting (Canada) -->
    <meta name="geo.region" content="CA" />
    <meta name="geo.placename" content="Canada" />
    <meta name="ICBM" content="56.1304, -106.3468" />

    <!-- Theme & app -->
    <meta name="theme-color" content="#0F766E" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#134E4A" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Shop Air Fresheners" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Keywords (top targets from Semrush research — Bing/Yandex still index these) -->
    <meta name="keywords" content="scent bomb canada, scent bomb, scent bomb spray, scent bomb air freshener, scent bomb for cars, scent bombs for cars, scent bomb for car, where to buy scent bomb, where can i buy scent bomb, bomb scents air fresheners, scent bomb black cherry, scent bomb vanilla, scent bomb clean cotton, scent bomb hawaiian blue, scent bomb mango tropical, scent bomb green bomb, scent bomb new car, scent bomb car freshener, scent bomb car air freshener, vehicle scent bomb, cherry bomb car scent, how to use scent bomb air freshener, how to use scent bomb, scent bombs for home, scent bombs for house, air freshener spray, air freshener spray canada, air freshener for bathroom, air fresheners for bathroom, bathroom air freshener, bathroom air fresheners, bathroom air freshener spray, bathroom spray, bathroom spray freshener, bathroom deodorant spray, bathroom fragrance spray, bathroom odor spray, bathroom refresh spray, bathroom scent spray, toilet spray, toilet air freshener, toilet air freshener spray, toilet air fresheners, best air freshener for toilet, poo toilet spray, poo spray for toilet, poop spray toilet, pre poop toilet spray, anti odor spray, air freshener room spray, room air freshener spray, car air freshener canada, concentrated air freshener spray" />

    <!-- Open Graph (Facebook, LinkedIn, Pinterest) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:locale:alternate" content="fr_CA" />
    <meta property="og:site_name" content="Shop Air Fresheners Canada" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:secure_url" content={OG_IMAGE} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content="Scent Bomb concentrated air fresheners — 9 fragrances available in Canada with 5-second odor elimination" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content="Scent Bomb concentrated air fresheners — 9 fragrances available in Canada" />
    <meta name="twitter:domain" content="shopairfresheners.ca" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#0F766E" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- DNS prefetch + preconnect (perf) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.amazon.ca" />
    <link rel="preconnect" href="https://d3e54v103j8qbb.cloudfront.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.amazon.ca" />

    <!-- LCP boost: preload hero image (desktop default, mobile uses media query) -->
    <link rel="preload" as="image" href="/images/Scent-Bomb-Air-Freshener-Sprays---Best-Sellers---Anti-Odor-Sprays-2-p-1080.webp" media="(min-width: 768px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/hero-mobile.webp" media="(max-width: 767px)" fetchpriority="high" />

    <!-- Webflow CSS -->
    <link href="/css/normalize.css" rel="stylesheet" type="text/css" />
    <link href="/css/webflow.css" rel="stylesheet" type="text/css" />
    <link href="/css/scent-bomb-air-fresheners.webflow.css" rel="stylesheet" type="text/css" />

    <!-- Google Fonts (Montserrat for BRISE branding + body) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&family=Montserrat+Alternates:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- BRISE Custom Styles (carried over from Webflow custom code) -->
    <style is:global>
      :root {
        --brise-teal: #0F766E;
        --brise-teal-deep: #134E4A;
        --brise-cream: #F5F1E8;
        --brise-teal-soft: rgba(15, 118, 110, 0.04);
      }

      html { scroll-behavior: smooth; scroll-padding-top: 110px; }

      /* NAVBAR STICKY — floating with breathing room at top */
      body > .navbar,
      .navbar,
      .navbar.w-nav,
      div.navbar.w-nav {
        position: fixed !important;
        top: 1rem !important;
        left: 0 !important;
        right: 0 !important;
        width: 100% !important;
        z-index: 9999 !important;
        background-color: transparent !important;
      }
      .navbar-component {
        backdrop-filter: blur(14px) !important;
        -webkit-backdrop-filter: blur(14px) !important;
        background-color: rgba(245, 241, 232, 0.88) !important;
        transition: all 0.3s ease !important;
        padding: 0.85rem 1.5rem !important;
        overflow: visible !important;
        align-items: center !important;
      }
      .navbar .right-navbar-content,
      .navbar .nav-menu,
      .navbar .button-border { align-items: center !important; }
      @media (max-width: 767px) {
        body > .navbar,
        .navbar,
        .navbar.w-nav,
        div.navbar.w-nav {
          top: 0.5rem !important;
        }
      }

      /* HERO IMAGE — Force visible on all breakpoints (Webflow theme hides on mobile by default) */
      .hero-image {
        display: block !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
        object-position: center !important;
      }
      .hero-background-2 {
        position: absolute !important;
        inset: 0 !important;
        z-index: 0 !important;
      }
      .hero-heading-2 { z-index: 5 !important; }
      .button-hero { z-index: 5 !important; }
      .hero-grid-2 { z-index: 4 !important; }

      /* MOBILE HERO — Image fills hero, original Webflow title style preserved (cream + shadow + teal underline) */
      @media (max-width: 767px) {
        .hero-wrapper-2 {
          background-color: #1a1a1a !important;
        }
        /* Slight dark overlay so cream H1 with text-shadow remains crisply readable */
        .hero-background-2::after {
          content: '';
          position: absolute;
          inset: 0;
          background: linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
          z-index: 1;
          pointer-events: none;
        }
        .hero-image {
          object-position: center center !important;
        }

        /* Hide the desktop circular STAY TUNED / EXPLORE button on mobile — CTA pill handles it */
        .button-hero { display: none !important; }
      }

      /* HERO CIRCULAR BUTTON — STAY TUNED → EXPLORE SCENTS */
      .button-hero {
        cursor: pointer !important;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
      }
      .button-hero .circular-text {
        animation: brise-spin 18s linear infinite;
        transition: animation-duration 0.4s ease;
        width: 100%;
        height: 100%;
        padding: 0 !important;
        inset: 0;
      }
      .button-hero .circular-text svg {
        width: 100%;
        height: 100%;
        display: block;
      }
      .button-hero .circular-text svg text {
        font-family: "Montserrat", sans-serif;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.08em;
        fill: var(--brise-teal-deep);
        text-transform: uppercase;
      }
      .button-hero:hover .circular-text {
        animation-duration: 6s;
      }
      .button-hero:hover .circular-text svg text {
        fill: var(--brise-teal);
      }
      .button-hero:hover {
        transform: scale(1.12) !important;
        box-shadow: 0 0 0 10px rgba(15, 118, 110, 0.18), 0 22px 50px rgba(15, 118, 110, 0.4) !important;
      }
      .button-hero:hover .button-arrow {
        animation: brise-bounce 0.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
      }
      .button-hero:active {
        transform: scale(0.97) !important;
        transition: transform 0.15s ease !important;
      }
      @keyframes brise-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      @keyframes brise-bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(4px); }
      }

      /* BRISE WORDMARK navbar */
      .brand .logo-navbar { display: none !important; }
      .brand::before {
        content: "BRISE";
        display: inline-block;
        font-family: "Montserrat", sans-serif;
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--brise-teal);
        text-transform: uppercase;
        line-height: 1;
        transition: color 0.3s ease;
      }
      .brand:hover::before { color: var(--brise-teal-deep); }

      /* NAV LINKS */
      .nav-menu .nav-link[href="/"],
      .nav-menu .nav-link[href="/contact"] { display: none !important; }
      .nav-menu .nav-link {
        font-family: "Montserrat", sans-serif !important;
        font-size: 0.88rem !important;
        font-weight: 500 !important;
        letter-spacing: 0.02em !important;
        color: var(--brise-teal-deep) !important;
        transition: color 0.3s ease !important;
        position: relative;
      }
      .nav-menu .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 1.5px;
        background: var(--brise-teal);
        transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .nav-menu .nav-link:hover { color: var(--brise-teal) !important; }
      .nav-menu .nav-link:hover::after { width: 100%; }

      /* BUY BUTTON */
      .button-navbar .text-size-small { font-size: 0; }
      .button-navbar .text-size-small::after {
        content: "BUY";
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.18em;
      }
      .button-navbar {
        background-color: var(--brise-teal) !important;
        color: var(--brise-cream) !important;
        padding: 8px 20px !important;
        border-radius: 999px !important;
        transition: all 0.3s ease !important;
        box-shadow: 0 4px 14px rgba(15, 118, 110, 0.3) !important;
        border: none !important;
        border-bottom: none !important;
        line-height: 1 !important;
        display: inline-flex !important;
        align-items: center !important;
      }
      .button-navbar:hover {
        border-bottom: none !important;
      }
      .button-navbar:hover {
        background-color: var(--brise-teal-deep) !important;
        transform: translateY(-1px);
        box-shadow: 0 8px 22px rgba(15, 118, 110, 0.45) !important;
      }

      /* FOOTER */
      .footer-link[href="/"],
      .footer-link[href="/products"],
      .footer-link[href="/contact"] { display: none !important; }
      .logo-footer { display: none !important; }
      .footer-heading::before {
        content: "BRISE";
        display: inline-block;
        font-family: "Montserrat", sans-serif;
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: 0.18em;
        color: var(--brise-teal);
        text-transform: uppercase;
        line-height: 1;
      }
      .footer-grid .footer-grid-wrap:nth-child(3),
      .footer-grid .footer-grid-wrap:nth-child(4),
      .footer-component .footer-links-wrapper > .footer-links,
      .credits-wrapper .credits { display: none !important; }
      .credits-wrapper p:first-child::after {
        content: " 2026 BRISE. Independent Canadian retailer. Scent Bomb® is a trademark of its respective owner.";
        color: rgba(0, 0, 0, 0.6);
        font-size: 0.78rem;
        letter-spacing: 0.01em;
        line-height: 1.5;
      }
      .credits-wrapper {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 0 !important;
      }
      .credits-wrapper p:first-child { margin: 0 !important; }
      .footer-social-wrapper .footer-social:nth-child(1),
      .footer-social-wrapper .footer-social:nth-child(2),
      .footer-social-wrapper .footer-social:nth-child(4) { display: none !important; }
      .footer-social-wrapper .footer-social:nth-child(3) { transition: all 0.3s ease; }
      .footer-social-wrapper .footer-social:nth-child(3):hover {
        transform: translateY(-2px);
        filter: brightness(0) saturate(100%) invert(28%) sepia(85%) saturate(450%) hue-rotate(127deg);
      }

      /* BEST SELLER BADGE */
      .best-seller-badge {
        position: absolute !important;
        top: 14px !important;
        right: 14px !important;
        left: auto !important;
        z-index: 5 !important;
        display: inline-flex !important;
        align-items: center !important;
        gap: 5px !important;
        padding: 6px 11px !important;
        border-radius: 999px !important;
        background-color: var(--brise-teal) !important;
        color: var(--brise-cream) !important;
        font-family: "Montserrat", sans-serif !important;
        font-size: 0.62rem !important;
        font-weight: 700 !important;
        letter-spacing: 0.16em !important;
        text-transform: uppercase !important;
        line-height: 1 !important;
